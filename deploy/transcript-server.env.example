# Install as /etc/transcript-server.env with mode 600, then replace the secrets.
TRANSCRIPT_HOST=0.0.0.0
TRANSCRIPT_PORT=8000
TRANSCRIPT_MODEL=large-v3
TRANSCRIPT_TOKEN=CHANGE_ME
HF_TOKEN=hf_xxx

# Durable extraction bundles (default: ~/.cache/transcript/extractions).
# TRANSCRIPT_DATA_DIR=/var/lib/transcript/extractions
# TRANSCRIPT_OCR_MODEL_DIR=/var/lib/transcript/ocr
