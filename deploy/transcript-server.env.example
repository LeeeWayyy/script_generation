# Install as /etc/transcript-server.env with mode 600, then replace the secrets.
# Direct CLI default: 127.0.0.1. This LAN bind requires the non-empty token below.
TRANSCRIPT_HOST=0.0.0.0
TRANSCRIPT_PORT=8000
TRANSCRIPT_MODEL=large-v3
# Required for the LAN bind above; leave empty until you set a strong random token.
TRANSCRIPT_TOKEN=
HF_TOKEN=hf_xxx

# Durable extraction bundles (default: ~/.cache/transcript/extractions).
# TRANSCRIPT_DATA_DIR=/var/lib/transcript/extractions
# TRANSCRIPT_EXTRACTION_TTL_SECONDS=604800
# TRANSCRIPT_OCR_MODEL_DIR=/var/lib/transcript/ocr

# Resource ceilings.
# TRANSCRIPT_MAX_DOWNLOAD_BYTES=8589934592
# TRANSCRIPT_DOWNLOAD_TIMEOUT_S=3600
# TRANSCRIPT_MAX_AUDIO_BYTES=8589934592
# TRANSCRIPT_AUDIO_TIMEOUT_S=3600
# TRANSCRIPT_MAX_IMAGE_PIXELS=100000000

# DANGEROUS: disables public-destination URL checks. Never enable on an exposed server.
# TRANSCRIPT_ALLOW_PRIVATE_FETCH=1
